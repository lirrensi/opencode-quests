{
    "name": "opencode-quests",
    "version": "0.2.0",
    "type": "module",
    "description": "Quest engine for OpenCode — labeled multi-next branching + persistent context via TUI injection + idle-driven re-fire",
    "main": "./src/index.ts",
    "keywords": [
        "opencode",
        "opencode-plugin",
        "plugin",
        "quest",
        "workflow",
        "stages",
        "state-machine",
        "branching"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lirrensi/opencode-quests.git"
    },
    "license": "MIT",
    "files": [
        "src",
        "README.md",
        "LICENSE"
    ],
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "sync": "node scripts/sync-plugins.mjs",
        "deploy": "node scripts/deploy.mjs"
    },
    "dependencies": {
        "@opencode-ai/plugin": "^1.15.11",
        "@opencode-ai/sdk": "^1.15.11",
        "yaml": "^2.7.0"
